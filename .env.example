# =============================================================================
# Mautic Monitor Dashboard — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o arquivo .env no repositório.
# =============================================================================

# -----------------------------------------------------------------------------
# 🔐 Segurança & Autenticação
# -----------------------------------------------------------------------------
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALLOWED_HOSTS=["http://localhost:3000","https://monitor.spacecrm.online"]

# -----------------------------------------------------------------------------
# 🗄️ Banco de Dados (TimescaleDB / PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://monitor_user:monitor_pass@db:5432/monitor_db
DB_HOST=db
DB_PORT=5432
DB_NAME=monitor_db
DB_USER=monitor_user
DB_PASSWORD=monitor_pass
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_ECHO=false
TIMESCALE_CHUNK_INTERVAL=1 day
TIMESCALE_RETENTION_POLICY=90 days

# -----------------------------------------------------------------------------
# ⏱️ Jobs Agendados (APScheduler)
# -----------------------------------------------------------------------------
SCHEDULER_JOB_DEFAULTS_COALESCE=true
SCHEDULER_JOB_DEFAULTS_MAX_INSTANCES=1
METRICS_COLLECT_INTERVAL_MINUTES=5
VPS_COLLECT_INTERVAL_MINUTES=15
MAUTIC_DB_COLLECT_INTERVAL_MINUTES=15
ALERT_ENGINE_INTERVAL_SECONDS=60
SCHEDULER_TIMEZONE=America/Sao_Paulo
SCHEDULER_MISFIRE_GRACE_TIME=30
JOB_STORE_TYPE=memory

# -----------------------------------------------------------------------------
# 📡 Integrações Externas — Mautic (timeouts e retries globais)
# Credenciais por instância são armazenadas no banco de dados.
# -----------------------------------------------------------------------------
MAUTIC_TIMEOUT_SECONDS=10
EXTERNAL_REQUEST_RETRY_ATTEMPTS=3
EXTERNAL_REQUEST_RETRY_DELAY_SECONDS=2

# -----------------------------------------------------------------------------
# 📧 Sendpost — Gateway de Email (alertas + coleta de stats)
# -----------------------------------------------------------------------------
SENDPOST_API_BASE_URL=https://api.sendpost.io/api/v1
SENDPOST_API_KEY=your-sendpost-subaccount-api-key
SENDPOST_ALERT_FROM_EMAIL=monitor@spacecrm.online
SENDPOST_ALERT_FROM_NAME=Space Monitor

# -----------------------------------------------------------------------------
# 📱 Avant SMS — Gateway de SMS (alertas + coleta de stats)
# -----------------------------------------------------------------------------
AVANT_SMS_API_BASE_URL=https://api.solucoesdigitais.dev
AVANT_SMS_TOKEN=your-avant-sms-token
AVANT_SMS_ALERT_FROM=SpaceCRM

# -----------------------------------------------------------------------------
# 🚨 Regras de Alerta
# -----------------------------------------------------------------------------
ALERT_THRESHOLD_CPU_WARNING=80
ALERT_THRESHOLD_CPU_CRITICAL=95
ALERT_THRESHOLD_MEMORY_WARNING=85
ALERT_THRESHOLD_MEMORY_CRITICAL=95
ALERT_THRESHOLD_DISK_WARNING=80
ALERT_THRESHOLD_DISK_CRITICAL=90
ALERT_THRESHOLD_EMAIL_DELTA_PCT=5
ALERT_THRESHOLD_SMS_DELTA_PCT=5
ALERT_THRESHOLD_API_LATENCY_MS=3000
ALERT_NO_CONTACTS_HOURS=24
ALERT_EVALUATION_WINDOW_MINUTES=5
ALERT_COOLDOWN_MINUTES=30
ALERT_MIN_SEVERITY_TO_NOTIFY=warning

# -----------------------------------------------------------------------------
# 🌐 Servidor & API
# -----------------------------------------------------------------------------
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=1
APP_RELOAD=true
LOG_LEVEL=info
LOG_FORMAT=text
API_V1_PREFIX=/api/v1
DOCS_ENABLED=true
REQUEST_TIMEOUT_SECONDS=30
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# -----------------------------------------------------------------------------
# 🐳 Docker / EasyPanel
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=mautic-monitor
EASYPANEL_DOMAIN=monitor.spacecrm.online
TZ=America/Sao_Paulo

# -----------------------------------------------------------------------------
# 🖥️ Frontend (Next.js — variáveis públicas)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Space Monitor
NEXT_PUBLIC_APP_ENV=development
